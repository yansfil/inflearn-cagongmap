# 카카오맵 JavaScript 앱 키
# 카카오 디벨로퍼스(https://developers.kakao.com) > 내 애플리케이션 > 앱 키 > JavaScript 키
# 카카오 디벨로퍼스 > 플랫폼 > Web 에 http://localhost:3030 도메인 등록 필요
#
# 아래 값을 실제 키로 채운 뒤 이 파일을 .env.local 로 복사하세요.
NEXT_PUBLIC_KAKAO_MAP_KEY=YOUR_KAKAO_JAVASCRIPT_KEY

# Supabase (places 테이블 읽기)
# Supabase 대시보드 > Project Settings > API
#   - Project URL → NEXT_PUBLIC_SUPABASE_URL
#   - Project API keys > anon public → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://wccsiuczufuxmfkfptem.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# 관리자 운영 콘솔 (/admin)
# Supabase 대시보드 > Project Settings > API > service_role secret
#   - 서버 전용. NEXT_PUBLIC_ 접두사 금지, 클라이언트에 노출되면 안 됨.
#   - places/제보 테이블 쓰기(RLS 우회)는 Server Action 에서 이 키로만 수행.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# 관리자 이메일 (쉼표 구분). /admin 접근 및 Server Action 권한 검증에 사용.
# 카카오 로그인이 반환하는 이메일과 일치해야 함(카카오 이메일 제공 동의 필요).
ADMIN_EMAILS=admin@example.com
